# SuperCrypto — Environment Configuration

# PostgreSQL connection string
DATABASE_URL=postgres://asmitadhikari@localhost:5432/supercrypto

# Server bind address
HOST=0.0.0.0
PORT=8080

# Log level: trace | debug | info | warn | error
RUST_LOG=info

# Bearer token for the /internal/* endpoints (price feed ingestion)
AUTH_TOKEN=dev-secret
JWT_SECRET=super-secret-default-key-for-development

CORS_ALLOW_ORIGIN=*
