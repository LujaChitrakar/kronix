# Path to a Solana keypair JSON file (array of 64 numbers).
# Default: ~/.config/solana/id.json
KEEPER_KEYPAIR_PATH=

# RPC endpoint. Devnet recommended for tests.
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Devnet USDC mint used by Kronix vault.
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Market index this keeper services. Single-market deployment for now.
NEXT_PUBLIC_MARKET_INDEX=24
NEXT_PUBLIC_SOL_MARKET_INDEX=24
NEXT_PUBLIC_KXI_MARKET_INDEX=23
NEXT_PUBLIC_MARKET_INDEXES=24,23
