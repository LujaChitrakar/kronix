# Solana keypair JSON array (64 numbers). File paths still work for local compat.
# Example: KEEPER_KEYPAIR_PATH=[1,2,...]
KEEPER_KEYPAIR_PATH=

# RPC endpoint. Devnet recommended for tests.
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Devnet USDC mint used by Kronix vault.
NEXT_PUBLIC_USDC_MINT=4VwXppbTdzQvzt7SsMYUpXdrZcytrQeixJFXUcgsEetF

# Market index this keeper services. Single-market deployment for now.
NEXT_PUBLIC_MARKET_INDEX=1
NEXT_PUBLIC_SOL_MARKET_INDEX=1
NEXT_PUBLIC_KXI_MARKET_INDEX=2
NEXT_PUBLIC_MARKET_INDEXES=1,2
